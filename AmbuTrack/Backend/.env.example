SMTP_USER=ambutrack.system.noreply@gmail.com
SMTP_PASS=<YOUR_APP_PASSWORD>
SMTP_FROM=AmbuTrack <ambutrack.system.noreply@gmail.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
NODE_ENV=development
PORT=5001

# Database placeholders - replace with real values
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=ambutrack_db
# Backend environment example for AmbuTrack
# Copy this file to .env and fill with real values before running the server

# Server
PORT=5001

# Database (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_db_password
DB_NAME=ambutrack

# SMTP (optional - required for real OTP emails)
# For Gmail use an App Password (requires 2-step verification). Do NOT commit real secrets.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your.email@gmail.com
SMTP_PASS=YOUR_GMAIL_APP_PASSWORD
SMTP_FROM="AmbuTrack <your.email@gmail.com>"

# Optional: allow the frontend to pick the backend URL (frontend also reads VITE_BACKEND_URL)
# VITE_BACKEND_URL=http://localhost:5001

# Notes:
# - After creating .env, restart the backend (npm run dev) to pick up changes.
# - Use the /mail-test endpoint to verify SMTP works:
#   curl -X POST http://localhost:5001/mail-test -H "Content-Type: application/json" -d '{"to":"you@example.com","subject":"test","text":"hello"}'
# - For OTP testing (dev mode without SMTP) the /send-otp endpoint returns the OTP in the JSON response.